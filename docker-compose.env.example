# Copy this file to `.env` in the repo root before building with Docker Compose.

# Published host ports
CLIENT_PORT=3000
SERVER_PORT=5000

# Browser-facing frontend origin. Keeping this on the frontend origin lets Next proxy
# `/api/*` requests to the backend through the rewrite in `client/next.config.ts`.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Next server-side proxy target used inside the Docker network
INTERNAL_API_BASE_URL=http://server:5000

# Backend CORS allowlist
CORS_ALLOWED_ORIGINS=http://localhost:3000
