# Copy this file to `.env` in the repo root before building with Docker Compose.

# Published host ports
CLIENT_PORT=3000
SERVER_PORT=5000

# Local Docker-based Supabase stack exposed by `npx supabase start`
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLIC_URL=http://127.0.0.1:54321
SUPABASE_INTERNAL_URL=http://host.docker.internal:54321
REPORT_ASSET_BASE_URL=http://host.docker.internal:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Browser-facing frontend origin. Keeping this on the frontend origin lets Next proxy
# `/api/*` requests to the backend through the rewrite in `client/next.config.ts`.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Next server-side proxy target used inside the Docker network
INTERNAL_API_BASE_URL=http://server:5000

# Backend CORS allowlist
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
